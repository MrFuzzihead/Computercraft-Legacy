function combine( ... )
    local r = 0
    for n,c in ipairs( { ... } ) do
        r = bit32.bor(r,c)
    end
    return r
end

function subtract( colors, ... )
	local r = colors
	for n,c in ipairs( { ... } ) do
		r = bit32.band(r, bit32.bnot(c))
	end
	return r
end

function test( colors, color )
    return ((bit32.band(colors, color)) == color)
end

-- Lookup table: valid color bitmask -> blit hex char, built at load time.
local tHex = {}
for i = 0, 15 do
    tHex[ 2 ^ i ] = string.format( "%x", i )
end

function packRGB( r, g, b )
    return math.floor( r * 255 ) * 65536
         + math.floor( g * 255 ) * 256
         + math.floor( b * 255 )
end

function unpackRGB( rgb )
    return
        math.floor( rgb / 65536 ) % 256 / 255,
        math.floor( rgb / 256   ) % 256 / 255,
        rgb % 256 / 255
end

function toBlit( color )
    -- O(1) fast path for the 16 valid color bitmasks.
    local result = tHex[ color ]
    if result then return result end
    -- Fallback for non-power-of-two inputs (behavior is undefined per spec,
    -- but we stay consistent with what a log2 floor would give).
    local index = 0
    local c = color
    while c > 1 do
        c = math.floor( c / 2 )
        index = index + 1
    end
    return string.format( "%x", index )
end

function fromBlit( char )
    -- Must be a single character; multi-char strings like "10" would
    -- otherwise parse as 16 and return 2^16 = 65536, which is wrong.
    if type( char ) ~= "string" or #char ~= 1 then return nil end
    local index = tonumber( char, 16 )
    if not index then return nil end
    return 2 ^ index
end

--- Converts between a hex color and its RGB components.
-- Dispatches to packRGB or unpackRGB depending on argument count.
-- @deprecated Use packRGB or unpackRGB directly.
function rgb8( r, g, b )
    if g == nil and b == nil then
        return unpackRGB( r )
    else
        return packRGB( r, g, b )
    end
end
